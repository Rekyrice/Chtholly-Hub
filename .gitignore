# --- 密钥与本地环境 ---
.env
.env.local
.env.*.local

# --- 本地文档（superpowers 工作流产物）---
docs/

# --- 构建产物 ---
apps/server/target/
apps/web/.next/
apps/web/out/
apps/web/node_modules/
scripts/oss/node_modules/

# --- 本地运行日志 ---
logs/*.log
*.log

# --- 本地文件存储 ---
uploads/
apps/server/uploads/

# --- 图片临时投放区（中转，不纳入版本库）---
apps/web/public/images/_incoming/*
!apps/web/public/images/_incoming/.gitkeep

# --- IDE / 编辑器（个人配置，不纳入版本库）---
.vscode/*
