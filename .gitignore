# --- 密钥与本地环境 ---
.env
.env.local
.env.*.local

# --- 本地与工作流文档 ---
docs/local/
docs/drafts/
docs/superpowers/
docs/补充.txt

# --- 构建产物 ---
apps/server/target/
apps/web/.next/
apps/web/out/
apps/web/node_modules/
scripts/oss/node_modules/

# --- Agent 隔离工作区与临时产物 ---
.worktrees/
.codex-tmp/
.superpowers/
content/seed/**/.media-prepare.lock/
content/seed/**/.media-staging-*/
.benchmark-results/

# --- 本地运行日志 ---
logs/*.log
*.log

# --- 本地文件存储 ---
uploads/
apps/server/uploads/

# --- 图片临时投放区（中转，不纳入版本库）---
apps/web/public/images/_incoming/*
!apps/web/public/images/_incoming/.gitkeep

# --- IDE / 编辑器（个人配置，不纳入版本库）---
.vscode/*
!.vscode/tasks.json
.cursor/*
!.cursor/mcp.json
!.cursor/rules/
!.cursor/rules/**
.idea/

# --- 操作系统 ---
.DS_Store
Thumbs.db
