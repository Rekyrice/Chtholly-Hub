# 复制为 .env 后供 docker compose -f docker-compose.prod.yml 使用
# 必填项请替换占位符；勿提交真实 .env

MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=chtholly

# 对外 HTTP 端口（Nginx）
HTTP_PORT=80

SITE_OWNER_USER_ID=1

# 阿里云 OSS（发帖与正文 URL）
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=chtholly-hub-dev
OSS_PUBLIC_DOMAIN=
OSS_FOLDER=post

# 生产 compose 内服务互联，无需改下列主机名
# MYSQL_HOST=mysql
# REDIS_HOST=redis
# ES_URIS=http://elasticsearch:9200
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092

CANAL_ENABLED=false
LLM_ENABLED=false
