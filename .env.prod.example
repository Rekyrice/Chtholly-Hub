# 复制为 .env 后供 docker compose -f docker-compose.prod.yml 使用
# 必填项请替换占位符；勿提交真实 .env

MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=chtholly

HTTP_PORT=80
SITE_OWNER_USER_ID=1

OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=chtholly-hub-dev
OSS_PUBLIC_DOMAIN=
OSS_FOLDER=post

CANAL_ENABLED=false
CANAL_PASSWORD=change_me_canal_password

# 前端来源白名单（逗号分隔）
CORS_ORIGINS=https://your-domain.example

# LLM / Agent（生产按需开启）
LLM_ENABLED=false
SPRING_PROFILES_ACTIVE=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
AGENT_MAX_STEPS=5
AGENT_MEMORY_MAX_TURNS=20
AGENT_MEMORY_TTL_MINUTES=120

# Bangumi
BANGUMI_ENABLED=true
BANGUMI_ACCESS_TOKEN=
BANGUMI_SYNC_ENABLED=false

# compose 内服务互联，一般无需改：
# MYSQL_HOST=mysql
# REDIS_HOST=redis
# ES_URIS=http://elasticsearch:9200
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
