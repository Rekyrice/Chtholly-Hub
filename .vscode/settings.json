{
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.jdt.ls.lombokSupport.enabled": true,
  "terminal.integrated.profiles.windows": {
    "Chtholly · 后端（验证码日志）": {
      "path": "powershell.exe",
      "args": [
        "-NoExit",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-backend.ps1"
      ],
      "icon": "server",
      "color": "terminal.ansiGreen"
    },
    "Chtholly · 前端": {
      "path": "powershell.exe",
      "args": [
        "-NoExit",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/dev/start-frontend.ps1"
      ],
      "icon": "globe",
      "color": "terminal.ansiCyan"
    }
  }
}
