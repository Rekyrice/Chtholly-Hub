# MySQL（库名 chtholly）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chtholly
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# Redis / Kafka / ES
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ES_URIS=http://localhost:9200

# 阿里云 OSS（Phase B 发帖；Phase A 种子 Markdown 需公网可读 URL）
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=chtholly-hub-dev
OSS_PUBLIC_DOMAIN=
OSS_FOLDER=post

# 站点（Phase A Feed 仅展示该用户帖子）
SITE_OWNER_USER_ID=1

# AI（Phase 4 才用，可先留空）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Canal（Phase A 关闭）
CANAL_ENABLED=false

# LLM / RAG（Phase A 关闭；需 API Key 后设为 true 并加 profile llm）
LLM_ENABLED=false
