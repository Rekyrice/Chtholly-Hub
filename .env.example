# 复制为 .env 后填写；勿提交 .env
# 启动：scripts/dev/start-backend.ps1（会读本文件）

# ── 服务端口 ──
SERVER_PORT=8888
API_SERVER_URL=http://localhost:8888

# ── MySQL（库名 chtholly）──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chtholly
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# ── Redis / Kafka / ES ──
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# 本地四个中间件均启动时设为 true；无 Kafka 时可 false（降级 Spring Event）
KAFKA_ENABLED=true
ES_URIS=http://localhost:9200
# 搜索索引副本数（开发 0，生产建议 1）
ES_REPLICAS=0

# ── 存储（local 无需 OSS；oss 需填写下方 OSS 配置）──
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# ── 阿里云 OSS（STORAGE_TYPE=oss 时必填；OSS_PUBLIC_DOMAIN 填 Bucket 公网域名）──
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=chtholly-hub-dev
OSS_PUBLIC_DOMAIN=
OSS_FOLDER=post

# ── 站点 ──
SITE_OWNER_USER_ID=1
# 站长初始密码（仅本地 .env 填写，勿提交；启动时写入 DB 后可删除此行）
OWNER_BOOTSTRAP_PASSWORD=
OWNER_HANDLE=Rekyrice
OWNER_NICKNAME=Rekyrice

# ── Canal（本地一般关闭）──
CANAL_ENABLED=false
CANAL_PASSWORD=Canal@123456

# ── CORS（后端允许的前端来源，逗号分隔；生产示例见 .env.prod.example）──
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── LLM / RAG / Agent（/agent 页；关闭时 LLM_ENABLED=false）──
LLM_ENABLED=false
# 启用 LLM 时必填；也可由 start-backend.ps1 在 LLM_ENABLED=true 时自动设为 llm
SPRING_PROFILES_ACTIVE=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# ── Agent ReAct ──
AGENT_MAX_STEPS=5
AGENT_MEMORY_MAX_TURNS=20
# Bangumi 等工具单次执行超时（秒）
AGENT_TOOL_TIMEOUT_SECONDS=30
# 会话记忆 Redis TTL（分钟），滑动过期：每次对话读写都会刷新
AGENT_MEMORY_TTL_MINUTES=120

# ── Bangumi（Agent bangumi_search；国内需代理访问 api.bgm.tv）──
BANGUMI_ENABLED=true
BANGUMI_ACCESS_TOKEN=
BANGUMI_SYNC_ENABLED=false
# 系统代理端口不对时可显式指定，如 http://127.0.0.1:7897
BANGUMI_HTTP_PROXY=
BANGUMI_USE_SYSTEM_PROXY=true

# ── 前端（Next.js，本地 dev 一般可不填）──
# NEXT_PUBLIC_OWNER_USER_ID=1
# NEXT_PUBLIC_API_SERVER_URL=http://localhost:8888
# NEXT_PUBLIC_WS_URL=ws://localhost:8888
